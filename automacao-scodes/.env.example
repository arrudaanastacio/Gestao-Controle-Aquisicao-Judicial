# Copie este arquivo para ".env" e preencha com seus dados.
# O arquivo .env fica SO na sua maquina (o .gitignore impede de ir ao GitHub).
# NUNCA coloque estes dados dentro do baixar_estoque.py.

# --- Acesso ao SCODES ---
SCODES_USUARIO=seu-usuario
SCODES_SENHA=sua-senha

# --- Cartao de seguranca ---
# Os 40 numeros do cartao, da posicao 1 ate a 40, separados por virgula.
# Ex.: SCODES_CARTAO=7384,7844,5726,...(ate a posicao 40)
SCODES_CARTAO=0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000,0000

# --- Pasta de rede onde o Excel sera salvo ---
SCODES_CAMINHO_REDE=G:\CAF\GAF\GGAF\PROGRAMAÇÃO\CPDAE\RELATÓRIO DE COMPRAS\2026\MEDICAMENTO\MACRO

# --- Opcional: rodar sem abrir a janela do navegador (1 = sim, 0 = nao) ---
SCODES_HEADLESS=0
