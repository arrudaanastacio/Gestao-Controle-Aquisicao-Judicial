# Dependências (reinstaláveis com "npm install")
node_modules/

# Configuração local com senhas/segredos — NUNCA versionar
.env
backend/.env

# Banco de dados com os dados reais do dia a dia.
# Ficar de fora do versionamento para que voltar uma versão do CÓDIGO
# não apague os dados de estoque/solicitações já cadastrados.
*.db
*.db-journal
*.db-wal
*.db-shm

# Exportações/dumps do banco (contêm dados e senhas) — não versionar
backend/data/export/

# Arquivos temporários do sistema
Thumbs.db
desktop.ini
*.log

# Estado interno dos vigias
backend/data/_vigia_estado.json
backend/_log.txt
backend/_err.txt

# Script auxiliar só para a ferramenta de preview do Claude Code
iniciar-preview.bat

# Pasta gerada pelo node-windows ao instalar o serviço (específica da máquina:
# executável do serviço, logs e config local). Recriada na instalação.
backend/src/daemon/
