# Adicione estas linhas ao seu .env existente (backend/.env)
# NÃO commite o .env. Se a senha tiver caractere especial (# $ espaço), use aspas.

ORA_USER=usuario_de_consulta
ORA_PASSWORD="senha_do_usuario"

# String de conexão Oracle (IP/porta/serviço). Fica só no .env para não
# expor a infraestrutura interna no repositório público.
# Formato: (DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=SEU_IP)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=SEU_SERVICO)))
ORA_CONNECT_STRING="(DESCRIPTION=(CONNECT_TIMEOUT=10)(RETRY_COUNT=3)(ADDRESS_LIST=(ADDRESS=(PROTOCOL=TCP)(HOST=SEU_IP)(PORT=1521)))(CONNECT_DATA=(SERVICE_NAME=SEU_SERVICO)(SERVER=DEDICATED)))"
