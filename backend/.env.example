PORT=3000
JWT_SECRET=troque-isto-por-um-texto-aleatorio-bem-grande-e-secreto
NODE_ENV=production

# Importação automática do estoque (vigia de arquivo CSV)
# Caminho do CSV monitorado. Quando o arquivo for atualizado, o sistema
# importa sozinho. Deixe em branco para usar o caminho padrão do projeto.
# MANTENHA false se AGENDAR_ORACLE_DIARIO=true (abaixo) estiver ligado: os
# dois escrevem na mesma tabela e rodar os dois ao mesmo tempo já causou
# erro de "database is locked" em produção. Só ligue de volta (true) se o
# Oracle ficar indisponível por muito tempo e for preciso voltar ao CSV manual.
CAMINHO_ESTOQUE_CSV=G:\CAF\GAF\GGAF\PROGRAMAÇÃO\CPDAE\RELATÓRIO DE COMPRAS\2026\MEDICAMENTO\MACRO\itens em estoque.csv
# Intervalo de verificação do arquivo, em milissegundos (padrão 30000 = 30s)
VIGIA_INTERVALO_MS=30000
AUTO_IMPORTAR_ESTOQUE=false

# Importação automática da Listagem de Autores (mesmo esquema do estoque)
# MANTENHA false pelo mesmo motivo acima (substituída pelo Oracle).
CAMINHO_AUTORES_CSV=G:\CAF\GAF\GGAF\PROGRAMAÇÃO\CPDAE\RELATÓRIO DE COMPRAS\2026\MEDICAMENTO\MACRO\Listagem de Autores.csv
AUTO_IMPORTAR_AUTORES=false

# Importação automática do Relatório de Itens (catálogo)
CAMINHO_RELATORIO_ITENS_CSV=G:\CAF\GAF\GGAF\PROGRAMAÇÃO\CPDAE\RELATÓRIO DE COMPRAS\2026\MEDICAMENTO\MACRO\Relatório de Itens.csv
AUTO_IMPORTAR_RELATORIO_ITENS=true

# Importação automática das Atas de Registro de Preço (SISCOA)
CAMINHO_ATAS_CSV=G:\CAF\GAF\GGAF\PROGRAMAÇÃO\CPDAE\RELATÓRIO DE COMPRAS\2026\MEDICAMENTO\MACRO\Atas SISCOA.xls
AUTO_IMPORTAR_ATAS=true

# Importação automática das Solicitações (Relatório de Compras Tenente Pena)
# Checa 2x ao dia (12h e 19h). Modo "substituir": atualiza status de linhas
# já existentes e insere as novas.
CAMINHO_SOLICITACOES=G:\CAF\GAF\GGAF\PROGRAMAÇÃO\CPDAE\RELATÓRIO DE COMPRAS\2026\MEDICAMENTO\RELATÓRIO DE COMPRAS TENENTE PENA - Macro.xlsm
AUTO_IMPORTAR_SOLICITACOES=true

# Importação automática das Solicitações de Outras Demandas (mesmo esquema,
# arquivo e layout de colunas diferentes; ignora abas FRONT PAGE e TABELA)
CAMINHO_SOLICITACOES_OD=G:\CAF\GAF\GGAF\PROGRAMAÇÃO\CPDAE\RELATÓRIO DE COMPRAS\2026\OUTRAS DEMANDAS\RELATÓRIO DE COMPRAS OUTRAS DEMANDAS - Macro.xlsm
AUTO_IMPORTAR_SOLICITACOES_OD=true

# Importação automática do módulo Distribuição (Status de Faturas + Extrato
# de Movimentações GSNET/IBL) — pasta com os 2 arquivos fixos:
#   1.Extrato Simples.xls, 2.Status Fatura WMS_IBL.xlsx
CAMINHO_DISTRIBUICAO=G:\CAF\GAF\GGAF\PROGRAMAÇÃO\CPDAE\GRADES DISTRIBUIÇÕES\2026\BANCO DE DADOS\RELATÓRIOS
AUTO_IMPORTAR_DISTRIBUICAO=true
# Opcional: pasta do cadastro "Cadastro Itens GSNET - IBL.xlsx" (mapeia o
# código do GSNET pro código SCODES). Padrão já aponta pra pasta correta
# (2026\BANCO DE DADOS) — só defina se mudar de lugar de novo.
# CAMINHO_BANCO_DADOS_DISTRIBUICAO=G:\CAF\GAF\GGAF\PROGRAMAÇÃO\CPDAE\GRADES DISTRIBUIÇÕES\2026\BANCO DE DADOS

# Login automático no SISCOA (usado pelo script de extração diária)
SISCOA_USUARIO=
SISCOA_SENHA=

# Backup diário automático do banco (backend/data/backups/, 1 arquivo por
# dia, mantém os últimos N dias). Ligado por padrão.
AUTO_BACKUP=true
BACKUP_HORA=5
BACKUP_MINUTO=0
BACKUP_RETENCAO_DIAS=14
# Quantos backups MENSAIS de longo prazo manter (1 por mês, guardados na
# subpasta backups/mensais). Padrão 12 (um ano).
BACKUP_MENSAL_MANTER=12
# Opcional: além da cópia local, copia também para essa pasta (ex.: dentro
# do Google Drive para Desktop). Deixe em branco para não copiar.
# A letra da unidade varia por computador — confira no Explorer do Windows
# (no Rafael, o Google Drive aparece como D:).
BACKUP_PASTA_DRIVE=D:\Backups Compras Judiciais
