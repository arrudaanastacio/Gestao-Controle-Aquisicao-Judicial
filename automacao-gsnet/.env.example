# Copie este arquivo para ".env" e preencha com seus dados de acesso ao GSNET.
# O arquivo .env fica SO na sua maquina (nao vai para o GitHub).
GSNET_USUARIO=31999918827
GSNET_SENHA=coloque-sua-senha-aqui

# Caminho do Chrome (ja detectado; so mude se necessario)
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Opcional: mudar o gestor/local padrao (senao usa 11 e 3004)
# GSNET_ID_GESTOR=11
# GSNET_ID_LOCAL=3004
